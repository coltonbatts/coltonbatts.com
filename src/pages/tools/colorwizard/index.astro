---
// /tools/colorwizard -- redirect to https://colorwizard.app/
// Static build: meta refresh + JS fallback.
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="refresh" content="0; url=https://colorwizard.app/" />
  <title>ColorWizard</title>
  <script is:inline>
    if (window) window.location.replace('https://colorwizard.app/');
  </script>
</head>
<body></body>
</html>
